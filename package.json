{
  "name": "ace-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "npm run test:node && npm run test:components",
    "test:node": "node --experimental-specifier-resolution=node --test \"lib/**/__tests__/*.test.ts\"",
    "test:components": "vitest run",
    "test:customer-send": "vitest run --config vitest.customer-send.config.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "check:full": "npm run lint && npm run typecheck && npm run build && npm run test"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "2.76.1",
    "lucide-react": "^0.575.0",
    "next": "16.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "swr": "^2.4.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
