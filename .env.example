# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Google OAuth / Calendar / Drive ──────────────────────────────────────────
# Client credentials from Google Cloud Console
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/google-calendar/callback
# Name of the calendar to sync (optional, defaults to primary)
# GOOGLE_WORK_CALENDAR_NAME=Work
# Google Drive folder ID for persisted estimate PDFs
# GOOGLE_DRIVE_ESTIMATES_FOLDER_ID=your-folder-id

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
APP_ORIGIN=https://your-domain.com
# Logo URL shown in customer-facing documents (optional)
# NEXT_PUBLIC_CRM_LOGO=https://your-domain.com/logo.png
# Review link shown to customers (optional)
# REVIEW_LINK=https://g.page/your-business/review
# NEXT_PUBLIC_REVIEW_LINK=https://g.page/your-business/review

# ── Cron authentication ───────────────────────────────────────────────────────
# Used by /api/internal/notes/reminders/run — set one of these
# NOTES_CRON_SECRET=your-cron-secret
# CRON_SECRET=your-cron-secret

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Default: in-memory (best-effort, resets on cold starts, not shared across
# Vercel instances). Set RATE_LIMIT_BACKEND=upstash and provide Upstash
# credentials to enable persistent cross-instance rate limiting.
# See the "Rate Limiting" section of README.md for upgrade instructions.
#
# RATE_LIMIT_BACKEND=upstash
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# ── Diagnostics (optional) ────────────────────────────────────────────────────
# Set to "1" to enable verbose server-side logs in production
# ACECRM_ENABLE_SERVER_LOGS=1
